#include <Servo.h>

Servo myServo1;
Servo myServo2;

const int servoPin1 = 6; //first servo
const int servoPin2 = 7; //second servo
const int copperPin1 = 2; //first
const int copperPin2 = 3; //second

bool hasRun1 = false;
bool hasRun2 = false;


void setup() {
  Serial.begin(9600);
  pinMode(copperPin1, INPUT_PULLUP);
  pinMode(copperPin2, INPUT_PULLUP);

  delay(2000);

  myServo1.attach(servoPin1);
  myServo1.write(90);
  delay(500);
  myServo1.detach();

  myServo2.attach(servoPin2);
  myServo2.write(90);
  delay(500); 
  myServo2.detach();
}

void triggerServo(Servo &servo, int pin, bool &hasRun, int sensorVal) {
  if (sensorVal == LOW && !hasRun) {
    hasRun = true;
    servo.attach(pin);
    servo.write(180);
    delay(600);
    servo.write(90);
    delay(200);
    servo.detach();
  }
  if (sensorVal == HIGH) {
    hasRun = false;
  }
}

void loop() {
  int sensorVal1 = digitalRead(copperPin1);
  int sensorVal2 = digitalRead(copperPin2);

  Serial.print("Sensor 1: ");
  Serial.print(sensorVal1);
  Serial.print("  Sensor 2: ");
  Serial.println(sensorVal2);

  triggerServo(myServo1, servoPin1, hasRun1, sensorVal1);
  triggerServo(myServo2, servoPin2, hasRun2, sensorVal2);

  delay(100);
}
